{
  "pool": "in_the_wild",
  "devices": [
    "mobile"
  ],
  "paths": {
    "base_path": "data/in_the_wild",
    "enrollment_base_path": "data/enrollments",
    "results_file": "{base_path}/results.csv"
  },
  "models": {
    "detector": "mediapipe",
    "embedder": {
      "model": "insightface",
      "config": {
        "min_detection_confidence": 0.6
      }
    }
  },
  "processing": {
    "skip_frames": 30,
    "matching_strategy": {
      "type": "random_sampling",
      "config": {
        "imposters_per_genuine": 5,
        "random_seed": 42
      }
    },
    "num_workers": 5
  },
  "authentication": {
    "backend": "risk_based",
    "risk_based": {
      "threshold": 1,
      "window_size": 5,
      "similarity_percentile": 0.90,
      "alpha": 1.0,
      "no_face_penalty": 1.5
    }
  },
  "enrollment": {
    "enrollment_video_preference": {
      "scenario": "easy",
      "rotations": [
        "cw",
        "ccw"
      ]
    },
    "frames_per_direction": 5,
    "frame_sampling_interval": 5,
    "yaw_threshold": 15.0,
    "pitch_threshold": 15.0,
    "distribution_mean_fraction": 0.5,
    "distribution_stddev_fraction": 0.25,
    "sampling_seed": 42
  },
  "imposter_creation": {
    "fps": 30,
    "genuine_user_seconds": 300,
    "black_screen_seconds": 3,
    "impostor_seconds": 300
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  },
  "participants": [
    {
      "name": "christina"
    },
    {
      "name": "gudrun"
    },
    {
      "name": "ulli"
    },
    {
      "name": "anna"
    },
    {
      "name": "lisi"
    },
    {
      "name": "bettina"
    },
    {
      "name": "alfred"
    },
    {
      "name": "max"
    }
  ]
}
