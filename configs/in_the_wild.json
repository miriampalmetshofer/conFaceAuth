{
  "pool": "in_the_wild",

  "paths": {
    "base_path": "../data/in_the_wild",
    "enrollment_base_path": "../data/enrollments",
    "results_file": "{base_path}/results.csv"
  },

  "models": {
    "detector": "mtcnn",
    "embedder": "Facenet"
  },

  "processing": {
    "skip_frames": 30,
    "devices": ["mobile"]
  },

  "authentication": {
    "threshold": 0.8,
    "window_size": 5,
    "similarity_percentile": 90.0,
    "alpha": 1.0,
    "no_face_penalty": 1.0
  },

  "enrollment": {
    "frames_per_direction": 5,
    "frame_sampling_interval": 5,
    "yaw_threshold": 15.0,
    "pitch_threshold": 15.0,
    "distribution_mean_fraction": 0.5,
    "distribution_stddev_fraction": 0.25,
    "sampling_seed": 42
  },

  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  },

  "participants": [
    {"name": "miriam"}
  ]
}
