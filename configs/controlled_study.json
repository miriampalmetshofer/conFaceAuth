{
  "pool": "controlled_study",
  "devices": [
    "desktop",
    "mobile"
  ],
  "paths": {
    "base_path": "data/controlled_study",
    "enrollment_base_path": "data/enrollments",
    "results_file": "{base_path}/results.csv"
  },
  "models": {
    "detector": "mediapipe",
    "embedder": {
      "model": "insightface",
      "config": {
        "min_detection_confidence": 0.6
      }
    }
  },
  "processing": {
    "skip_frames": 30,
    "matching_strategy": {
      "type": "scenario",
      "config": {}
    },
    "num_workers": 4
  },
  "authentication": {
    "backend": "temporal_decay",
    "fps": 30,
    "temporal_decay": {
      "threshold": 0.5,
      "similarity_percentile": 0.90,
      "k_weight": 45000,
      "k_decay": 60000,
      "initial_confidence": 1
    }
  },
  "enrollment": {
    "enrollment_video_preference": {
      "scenarios": [
        "easy"
      ],
      "rotations": [
        "cw",
        "ccw"
      ]
    },
    "force_reenrollment": true,
    "backend": "fixed_order",
    "config": {
      "window_seconds": 2.0
    },
    "frames_per_direction": 5
  },
  "imposter_creation": {
    "fps": 30,
    "genuine_user_seconds": 180,
    "black_screen_seconds": 3,
    "impostor_seconds": 180
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  },
  "participants": [
     {
      "name": "christina"
    },
    {
      "name": "gudrun"
    },
    {
      "name": "ulli"
    },
    {
      "name": "anna"
    }
  ]
}
