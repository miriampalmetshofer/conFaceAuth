{
  "pool": "controlled_study",
  "paths": {
    "base_path": "data/controlled_study",
    "enrollment_base_path": "data/enrollments",
    "results_file": "{base_path}/results.csv"
  },
  "models": {
    "detector": "mtcnn",
    "embedder": "facenet"
  },
  "processing": {
    "skip_frames": 30,
    "devices": [
      "mobile",
      "desktop"
    ]
  },
  "authentication": {
    "threshold": 0.95,
    "window_size": 5,
    "similarity_percentile": 0.90,
    "alpha": 1.0,
    "no_face_penalty": 1.5
  },
  "enrollment": {
    "enrollment_video_preference": {
      "scenario": "easy",
      "rotations": [
        "cw",
        "ccw"
      ]
    },
    "frames_per_direction": 5,
    "frame_sampling_interval": 5,
    "yaw_threshold": 15.0,
    "pitch_threshold": 15.0,
    "distribution_mean_fraction": 0.5,
    "distribution_stddev_fraction": 0.25,
    "sampling_seed": 42
  },
  "imposter_creation": {
    "fps": 30,
    "genuine_user_seconds": 180,
    "black_screen_seconds": 3,
    "impostor_seconds": 180
  },
  "logging": {
    "level": "DEBUG",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  },
  "participants": [
    {
      "name": "christina"
    },
    {
      "name": "gudrun"
    },
    {
      "name": "ulli"
    },
    {
      "name": "anna"
    },
    {
      "name": "lisi"
    },
    {
      "name": "bettina"
    },
    {
      "name": "alfred"
    },
    {
      "name": "max"
    }
  ]
}
